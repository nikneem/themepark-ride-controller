{
  "mcpServers": {
    "aspire": {
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
        "primeng": {
      "command": "npx",
      "args": ["-y", "@primeng/mcp"]
    },
    "hexmaster-design-guidelines": {
      "type": "stdio",
      "command": "hexmaster-codingguidelines-mcpserver",
      "args": []
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    }
  }
}